# Copy to .env and fill in. Everything here is optional — with no keys the app
# runs in deterministic offline mode (still fully end-to-end).

# --- LLM (synthesis, conflict adjudication, norm extraction) -----------------
# Without this, kaixn uses the offline NaiveSynthesizer + structural checks only.
ANTHROPIC_API_KEY=

# --- Embeddings --------------------------------------------------------------
# fake   -> deterministic, no network, dim 64   (default; great for demos)
# openai -> text-embedding-3-small, dim 1536    (needs OPENAI_API_KEY)
# ollama -> local nomic-embed-text, dim 768     (needs an Ollama server)
KAIXN_EMBEDDER=fake
OPENAI_API_KEY=

# --- Database ----------------------------------------------------------------
# Set to use Postgres (PgStore). Unset -> in-memory store (resets on restart).
# docker compose sets this automatically; for local dev point at your own PG.
# KAIXN_DSN=postgresql://kaixn:kaixn@localhost:5432/kaixn

# --- Server ------------------------------------------------------------------
PORT=8000
